#lang racket/base
;; AUTO-GENERATED by tools/build

(module reader syntax/module-reader
  ~BASE-LANG~
  #:wrapper1
  (let ()
    ;; ===== helpers =====
    (define (hash-merge a b)
      (for/fold ([h a]) ([(k v) (in-hash b)]) (hash-set h k v)))

    ;; ===== state =====
    (define active-id (box (hash)))
    (define active-kw (box (hash)))
    (define loaded    (box (list)))

    ;; tables dir: relative to this file (build 时填充)
    (define tables-root
      (let* ([mpi (variable-reference->module-path-index (#%variable-reference))]
             [rmp (module-path-index-resolve mpi)]
             [f   (resolved-module-path-name rmp)]
             [s   (if (path? f) (path->string f)
                      (if (pair? f) (path->string (car f)) f))]
             [i   (let loop ([i (sub1 (string-length s))])
                    (if (char=? (string-ref s i) #\/) i (loop (sub1 i))))])
        (string-append (substring s 0 i) "/~TABLES-PATH~")))

    ;; ===== load .rktd =====
    (define (read-table-file path)
      (with-handlers ([exn:fail? (lambda (_) (values (hash) (hash) '()))])
        (call-with-input-file path
          (lambda (in) (values (read in) (read in) (read in))))))

    ;; ===== load table + recursive deps =====
    (define (load-table! mod-path)
      (when (not (member mod-path (unbox loaded)))
        (set-box! loaded (cons mod-path (unbox loaded)))
        (let-values ([(id kw deps)
                      (read-table-file
                       (string-append tables-root "/" mod-path ".rktd"))])
          (set-box! active-id (hash-merge (unbox active-id) id))
          (set-box! active-kw (hash-merge (unbox active-kw) kw))
          (for ([d (in-list deps)])
            (load-table! d)))))

    ;; ===== preload =====
    (load-table! "~PRELOAD~")

    ;; ===== require handling =====
    (define (try-load-module-table! sym)
      (define mod-str (symbol->string sym))
      (define table-file (string-append tables-root "/" mod-str ".rktd"))
      (when (file-exists? table-file)
        (load-table! mod-str)))

    (define (translate-require-arg arg)
      (define d (syntax-e arg))
      (cond
        [(symbol? d)
         (define en (hash-ref (unbox active-id) d #f))
         (define real (or en d))
         (try-load-module-table! real)
         real]
        [(pair? d)
         (map translate-require-arg (syntax->list arg))]
        [else d]))

    ;; ===== main traversal =====
    (define (translate-one stx)
      (syntax-case stx ()
        [(a . b)
         (let* ([ca-stx (translate-one #'a)]
                [ca (syntax-e ca-stx)])
           (if (eq? ca 'require)
               (let ([args (map translate-require-arg (syntax->list #'b))])
                 (datum->syntax stx (cons ca args) stx stx))
               (let ([cd (syntax-e (translate-one #'b))])
                 (datum->syntax stx (cons ca cd) stx stx))))]
        [kw (keyword? (syntax-e #'kw))
         (let ([en (hash-ref (unbox active-kw) (syntax-e #'kw) #f)])
           (if en (datum->syntax #'kw en #'kw #'kw) #'kw))]
        [id (identifier? #'id)
         (let ([en (hash-ref (unbox active-id) (syntax-e #'id) #f)])
           (if en (datum->syntax #'id en #'id #'id) #'id))]
        [_ stx]))

    (define (translate r)
      (cond [(list? r) (map translate-one r)]
            [(syntax? r) (translate-one r)]
            [else r]))

    (lambda (thunk) (translate (thunk)))))
